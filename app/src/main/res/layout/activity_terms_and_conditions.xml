<?xml version="1.0" encoding="utf-8"?>
<carbon.widget.RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:fitsSystemWindows="true"
    tools:context=".activity.TermsAndConditions">

    <carbon.widget.RelativeLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="16dp"
        android:paddingHorizontal="20dp"
        android:background="@color/black"
        android:elevation="4dp">

        <carbon.widget.ImageView
            android:id="@+id/back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_centerVertical="true"
            android:contentDescription="Back"
            android:padding="6dp"
            android:src="@drawable/ic_back"
            app:carbon_tint="@color/white" />

        <carbon.widget.TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="12dp"
            android:layout_toEndOf="@id/back"
            android:fontFamily="@font/main_font"
            android:text="Terms &amp; Conditions"
            android:textColor="@color/white"
            android:textSize="26sp"
            android:textStyle="bold" />

    </carbon.widget.RelativeLayout>

    <View
        android:id="@+id/header_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_below="@id/header"
        android:background="#2A2A2A"/>

    <carbon.widget.ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header_divider"
        android:scrollbars="none"
        android:fillViewport="true">

        <carbon.widget.LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="32dp">

            <carbon.widget.TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/main_font"
                android:text="1. Agreement to Terms"
                android:textColor="@color/carbon_blue_700"
                android:textSize="20sp"
                android:textStyle="bold" />

            <carbon.widget.TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:fontFamily="@font/main_font"
                android:text="By accessing and using this application, you accept and agree to be bound by the terms and provisions of this agreement. If you do not agree to these Terms and Conditions, please do not use this app."
                android:textColor="#B8B8B8"
                android:textSize="15sp"
                android:lineSpacingExtra="4dp" />

            <carbon.widget.TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/main_font"
                android:text="2. Use License"
                android:textColor="@color/carbon_blue_700"
                android:textSize="20sp"
                android:textStyle="bold" />

            <carbon.widget.TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/main_font"
                android:text="Permission is granted to temporarily download one copy of the application for personal, non-commercial transitory viewing only. This is the grant of a license, not a transfer of title, and under this license you may not:"
                android:textColor="#B8B8B8"
                android:textSize="15sp"
                android:lineSpacingExtra="4dp" />

            <carbon.widget.LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp"
                android:paddingStart="16dp"
                android:paddingEnd="0dp">

                <carbon.widget.LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <carbon.widget.TextView
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginEnd="12dp"
                        android:background="@color/carbon_blue_700" />

                    <carbon.widget.TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/main_font"
                        android:text="Modify or copy the application materials"
                        android:textColor="#B8B8B8"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp" />

                </carbon.widget.LinearLayout>

                <carbon.widget.LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <carbon.widget.TextView
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginEnd="12dp"
                        android:background="@color/carbon_blue_700" />

                    <carbon.widget.TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/main_font"
                        android:text="Use the materials for any commercial purpose"
                        android:textColor="#B8B8B8"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp" />

                </carbon.widget.LinearLayout>

                <carbon.widget.LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <carbon.widget.TextView
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginEnd="12dp"
                        android:background="@color/carbon_blue_700" />

                    <carbon.widget.TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/main_font"
                        android:text="Attempt to decompile or reverse engineer any software"
                        android:textColor="#B8B8B8"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp" />

                </carbon.widget.LinearLayout>

                <carbon.widget.LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <carbon.widget.TextView
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginEnd="12dp"
                        android:background="@color/carbon_blue_700" />

                    <carbon.widget.TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/main_font"
                        android:text="Remove any copyright or proprietary notations"
                        android:textColor="#B8B8B8"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp" />

                </carbon.widget.LinearLayout>

            </carbon.widget.LinearLayout>

            <carbon.widget.TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/main_font"
                android:text="3. User Accounts"
                android:textColor="@color/carbon_blue_700"
                android:textSize="20sp"
                android:textStyle="bold" />

            <carbon.widget.TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:fontFamily="@font/main_font"
                android:text="When you create an account with us, you must provide accurate, complete, and current information. You are responsible for safeguarding the password and for all activities that occur under your account."
                android:textColor="#B8B8B8"
                android:textSize="15sp"
                android:lineSpacingExtra="4dp" />

            <carbon.widget.TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/main_font"
                android:text="4. Prohibited Uses"
                android:textColor="@color/carbon_blue_700"
                android:textSize="20sp"
                android:textStyle="bold" />

            <carbon.widget.TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/main_font"
                android:text="You may not use the app:"
                android:textColor="#B8B8B8"
                android:textSize="15sp"
                android:lineSpacingExtra="4dp" />

            <carbon.widget.LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp"
                android:paddingStart="16dp"
                android:paddingEnd="0dp">

                <carbon.widget.LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <carbon.widget.TextView
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginEnd="12dp"
                        android:background="@color/carbon_blue_700" />

                    <carbon.widget.TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/main_font"
                        android:text="In any way that violates any applicable law or regulation"
                        android:textColor="#B8B8B8"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp" />

                </carbon.widget.LinearLayout>

                <carbon.widget.LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <carbon.widget.TextView
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginEnd="12dp"
                        android:background="@color/carbon_blue_700" />

                    <carbon.widget.TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/main_font"
                        android:text="To transmit any advertising or promotional material"
                        android:textColor="#B8B8B8"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp" />

                </carbon.widget.LinearLayout>

                <carbon.widget.LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <carbon.widget.TextView
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginEnd="12dp"
                        android:background="@color/carbon_blue_700" />

                    <carbon.widget.TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/main_font"
                        android:text="To impersonate or attempt to impersonate others"
                        android:textColor="#B8B8B8"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp" />

                </carbon.widget.LinearLayout>

                <carbon.widget.LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <carbon.widget.TextView
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginEnd="12dp"
                        android:background="@color/carbon_blue_700" />

                    <carbon.widget.TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/main_font"
                        android:text="To engage in any harmful or malicious behavior"
                        android:textColor="#B8B8B8"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp" />

                </carbon.widget.LinearLayout>

            </carbon.widget.LinearLayout>

            <carbon.widget.TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/main_font"
                android:text="5. Intellectual Property"
                android:textColor="@color/carbon_blue_700"
                android:textSize="20sp"
                android:textStyle="bold" />

            <carbon.widget.TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:fontFamily="@font/main_font"
                android:text="The app and its original content, features, and functionality are owned by us and are protected by international copyright, trademark, patent, trade secret, and other intellectual property laws."
                android:textColor="#B8B8B8"
                android:textSize="15sp"
                android:lineSpacingExtra="4dp" />

            <carbon.widget.TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/main_font"
                android:text="6. Termination"
                android:textColor="@color/carbon_blue_700"
                android:textSize="20sp"
                android:textStyle="bold" />

            <carbon.widget.TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:fontFamily="@font/main_font"
                android:text="We may terminate or suspend your account and access to the app immediately, without prior notice or liability, for any reason, including breach of these Terms. Upon termination, your right to use the app will cease immediately."
                android:textColor="#B8B8B8"
                android:textSize="15sp"
                android:lineSpacingExtra="4dp" />

            <carbon.widget.TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/main_font"
                android:text="7. Limitation of Liability"
                android:textColor="@color/carbon_blue_700"
                android:textSize="20sp"
                android:textStyle="bold" />

            <carbon.widget.TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:fontFamily="@font/main_font"
                android:text="In no event shall we be liable for any indirect, incidental, special, consequential, or punitive damages, including without limitation, loss of profits, data, use, or other intangible losses, resulting from your access to or use of the app."
                android:textColor="#B8B8B8"
                android:textSize="15sp"
                android:lineSpacingExtra="4dp" />

            <carbon.widget.TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/main_font"
                android:text="8. Changes to Terms"
                android:textColor="@color/carbon_blue_700"
                android:textSize="20sp"
                android:textStyle="bold" />

            <carbon.widget.TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:fontFamily="@font/main_font"
                android:text="We reserve the right to modify or replace these Terms at any time. If a revision is material, we will provide at least 30 days' notice prior to any new terms taking effect. Continued use of the app after changes constitutes acceptance of the new Terms."
                android:textColor="#B8B8B8"
                android:textSize="15sp"
                android:lineSpacingExtra="4dp" />

            <carbon.widget.TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/main_font"
                android:text="9. Contact Information"
                android:textColor="@color/carbon_blue_700"
                android:textSize="20sp"
                android:textStyle="bold" />

            <carbon.widget.TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:fontFamily="@font/main_font"
                android:text="If you have any questions about these Terms and Conditions, please contact us:"
                android:textColor="#B8B8B8"
                android:textSize="15sp"
                android:lineSpacingExtra="4dp" />

            <carbon.widget.LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1A1A1A"
                android:padding="20dp">

                <carbon.widget.LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <carbon.widget.ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginEnd="12dp"
                        app:carbon_tint="@color/carbon_blue_700"
                        android:src="@drawable/ic_mail" />

                    <carbon.widget.TextView
                        android:id="@+id/email_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/main_font"
                        android:text="legal@yourapp.com"
                        android:textColor="@color/white"
                        android:textSize="15sp" />

                </carbon.widget.LinearLayout>

                <carbon.widget.LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <carbon.widget.ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginEnd="12dp"
                        app:carbon_tint="@color/carbon_blue_700"
                        android:src="@drawable/ic_web" />

                    <carbon.widget.TextView
                        android:id="@+id/website_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/main_font"
                        android:text="www.yourapp.com/terms"
                        android:textColor="@color/white"
                        android:textSize="15sp" />

                </carbon.widget.LinearLayout>

            </carbon.widget.LinearLayout>

            <carbon.widget.LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="24dp"
                android:background="#0D47A1"
                app:carbon_cornerRadius="15dp"
                android:padding="20dp">

                <carbon.widget.TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="@font/main_font"
                    android:text="By using this app, you acknowledge that you have read and understood these Terms and Conditions and agree to be bound by them."
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp"
                    android:textStyle="bold" />

            </carbon.widget.LinearLayout>

        </carbon.widget.LinearLayout>

    </carbon.widget.ScrollView>

</carbon.widget.RelativeLayout>