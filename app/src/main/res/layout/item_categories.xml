<?xml version="1.0" encoding="utf-8"?>
<carbon.widget.RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginVertical="10dp"
    android:layout_marginHorizontal="5dp"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <carbon.widget.TextView
        android:id="@+id/categoryTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/glassmorphism2"
        android:fontFamily="@font/main_font"
        android:paddingStart="20dp"
        android:paddingTop="6dp"
        android:paddingEnd="20dp"
        android:paddingBottom="6dp"
        android:text="All"
        android:textColor="@color/white"
        android:textSize="22sp"
        app:carbon_cornerRadius="15dp"
        app:carbon_stroke="@color/carbon_grey_500"
        app:carbon_strokeWidth="1dp" />

</carbon.widget.RelativeLayout>