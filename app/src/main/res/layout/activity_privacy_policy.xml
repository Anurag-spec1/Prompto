<?xml version="1.0" encoding="utf-8"?>
<carbon.widget.RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:fitsSystemWindows="true"
    tools:context=".activity.PrivacyPolicy">

    <carbon.widget.RelativeLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="16dp"
        android:paddingHorizontal="20dp"
        android:background="@color/black"
        android:elevation="4dp">

        <carbon.widget.ImageView
            android:id="@+id/back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_centerVertical="true"
            android:contentDescription="Back"
            android:padding="6dp"
            android:src="@drawable/ic_back"
            app:carbon_tint="@color/white" />

        <carbon.widget.TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="12dp"
            android:layout_toEndOf="@id/back"
            android:fontFamily="@font/main_font"
            android:text="Privacy Policy"
            android:textColor="@color/white"
            android:textSize="26sp"
            android:textStyle="bold" />

    </carbon.widget.RelativeLayout>

    <View
        android:id="@+id/header_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_below="@id/header"
        android:background="#2A2A2A"/>

    <carbon.widget.ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header_divider"
        android:scrollbars="none"
        android:fillViewport="true">

        <carbon.widget.LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="32dp">

            <carbon.widget.TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/main_font"
                android:text="Introduction"
                android:textColor="@color/carbon_blue_700"
                android:textSize="20sp"
                android:textStyle="bold" />

            <carbon.widget.TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:fontFamily="@font/main_font"
                android:text="We value your privacy and are committed to protecting your personal information. This Privacy Policy explains how we collect, use, and safeguard your data when you use our application."
                android:textColor="#B8B8B8"
                android:textSize="15sp"
                android:lineSpacingExtra="4dp" />

            <carbon.widget.TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/main_font"
                android:text="Information We Collect"
                android:textColor="@color/carbon_blue_700"
                android:textSize="20sp"
                android:textStyle="bold" />

            <carbon.widget.TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/main_font"
                android:text="We may collect the following types of information:"
                android:textColor="#B8B8B8"
                android:textSize="15sp"
                android:lineSpacingExtra="4dp" />

            <carbon.widget.LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp"
                android:paddingStart="16dp"
                android:paddingEnd="0dp">

                <carbon.widget.LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <carbon.widget.TextView
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginEnd="12dp"
                        android:background="@color/carbon_blue_700" />

                    <carbon.widget.TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/main_font"
                        android:text="Device information (model, operating system, unique identifiers)"
                        android:textColor="#B8B8B8"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp" />

                </carbon.widget.LinearLayout>

                <carbon.widget.LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <carbon.widget.TextView
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginEnd="12dp"
                        android:background="@color/carbon_blue_700" />

                    <carbon.widget.TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/main_font"
                        android:text="Usage data (app interactions, features used, session duration)"
                        android:textColor="#B8B8B8"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp" />

                </carbon.widget.LinearLayout>

                <carbon.widget.LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <carbon.widget.TextView
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginEnd="12dp"
                        android:background="@color/carbon_blue_700" />

                    <carbon.widget.TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/main_font"
                        android:text="Log data (IP address, browser type, access times)"
                        android:textColor="#B8B8B8"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp" />

                </carbon.widget.LinearLayout>

            </carbon.widget.LinearLayout>

            <!-- How We Use Your Information -->
            <carbon.widget.TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/main_font"
                android:text="How We Use Your Information"
                android:textColor="@color/carbon_blue_700"
                android:textSize="20sp"
                android:textStyle="bold" />

            <carbon.widget.TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/main_font"
                android:text="We use the collected information to:"
                android:textColor="#B8B8B8"
                android:textSize="15sp"
                android:lineSpacingExtra="4dp" />

            <carbon.widget.LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp"
                android:paddingStart="16dp"
                android:paddingEnd="0dp">

                <carbon.widget.LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <carbon.widget.TextView
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginEnd="12dp"
                        android:background="@color/carbon_blue_700"/>

                    <carbon.widget.TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/main_font"
                        android:text="Provide and maintain our services"
                        android:textColor="#B8B8B8"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp" />

                </carbon.widget.LinearLayout>

                <carbon.widget.LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <carbon.widget.TextView
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginEnd="12dp"
                        android:background="@color/carbon_blue_700" />

                    <carbon.widget.TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/main_font"
                        android:text="Improve and personalize user experience"
                        android:textColor="#B8B8B8"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp" />

                </carbon.widget.LinearLayout>

                <carbon.widget.LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <carbon.widget.TextView
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginEnd="12dp"
                        android:background="@color/carbon_blue_700" />

                    <carbon.widget.TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/main_font"
                        android:text="Analyze app performance and fix technical issues"
                        android:textColor="#B8B8B8"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp" />

                </carbon.widget.LinearLayout>

                <carbon.widget.LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <carbon.widget.TextView
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginEnd="12dp"
                        android:background="@color/carbon_blue_700" />

                    <carbon.widget.TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/main_font"
                        android:text="Send notifications and updates about our services"
                        android:textColor="#B8B8B8"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp" />

                </carbon.widget.LinearLayout>

            </carbon.widget.LinearLayout>

            <carbon.widget.TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/main_font"
                android:text="Data Security"
                android:textColor="@color/carbon_blue_700"
                android:textSize="20sp"
                android:textStyle="bold" />

            <carbon.widget.TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:fontFamily="@font/main_font"
                android:text="We implement appropriate security measures to protect your personal information from unauthorized access, alteration, disclosure, or destruction. However, no method of transmission over the internet is 100% secure."
                android:textColor="#B8B8B8"
                android:textSize="15sp"
                android:lineSpacingExtra="4dp" />

            <carbon.widget.TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/main_font"
                android:text="Third-Party Services"
                android:textColor="@color/carbon_blue_700"
                android:textSize="20sp"
                android:textStyle="bold" />

            <carbon.widget.TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:fontFamily="@font/main_font"
                android:text="Our app may contain links to third-party services that are not operated by us. We strongly advise you to review the Privacy Policy of these third-party services. We have no control over and assume no responsibility for their content or practices."
                android:textColor="#B8B8B8"
                android:textSize="15sp"
                android:lineSpacingExtra="4dp" />

            <carbon.widget.TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/main_font"
                android:text="Your Rights"
                android:textColor="@color/carbon_blue_700"
                android:textSize="20sp"
                android:textStyle="bold" />

            <carbon.widget.TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/main_font"
                android:text="You have the right to:"
                android:textColor="#B8B8B8"
                android:textSize="15sp"
                android:lineSpacingExtra="4dp" />

            <carbon.widget.LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp"
                android:paddingStart="16dp"
                android:paddingEnd="0dp">

                <carbon.widget.LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <carbon.widget.TextView
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginEnd="12dp"
                        android:background="@color/carbon_blue_700" />

                    <carbon.widget.TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/main_font"
                        android:text="Access and receive a copy of your personal data"
                        android:textColor="#B8B8B8"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp" />

                </carbon.widget.LinearLayout>

                <carbon.widget.LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <carbon.widget.TextView
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginEnd="12dp"
                        android:background="@color/carbon_blue_700"/>

                    <carbon.widget.TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/main_font"
                        android:text="Request correction of inaccurate data"
                        android:textColor="#B8B8B8"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp" />

                </carbon.widget.LinearLayout>

                <carbon.widget.LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <carbon.widget.TextView
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginEnd="12dp"
                        android:background="@color/carbon_blue_700" />

                    <carbon.widget.TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/main_font"
                        android:text="Request deletion of your personal data"
                        android:textColor="#B8B8B8"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp" />

                </carbon.widget.LinearLayout>

                <carbon.widget.LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <carbon.widget.TextView
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginEnd="12dp"
                        android:background="@color/carbon_blue_700" />

                    <carbon.widget.TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/main_font"
                        android:text="Object to processing of your data"
                        android:textColor="#B8B8B8"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp" />

                </carbon.widget.LinearLayout>

            </carbon.widget.LinearLayout>

            <carbon.widget.TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/main_font"
                android:text="Contact Us"
                android:textColor="@color/carbon_blue_700"
                android:textSize="20sp"
                android:textStyle="bold" />

            <carbon.widget.TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:fontFamily="@font/main_font"
                android:text="If you have any questions or concerns about this Privacy Policy, please contact us:"
                android:textColor="#B8B8B8"
                android:textSize="15sp"
                android:lineSpacingExtra="4dp" />

            <carbon.widget.LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1A1A1A"
                app:carbon_cornerRadius="8dp"
                android:padding="20dp">

                <carbon.widget.LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <carbon.widget.ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginEnd="12dp"
                        app:carbon_tint="@color/carbon_blue_700"
                        android:src="@drawable/ic_mail" />

                    <carbon.widget.TextView
                        android:id="@+id/email_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/main_font"
                        android:text="support@yourapp.com"
                        android:textColor="@color/white"
                        android:textSize="15sp" />

                </carbon.widget.LinearLayout>

                <carbon.widget.LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <carbon.widget.ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginEnd="12dp"
                        app:carbon_tint="@color/carbon_blue_700"
                        android:src="@drawable/ic_web" />

                    <carbon.widget.TextView
                        android:id="@+id/website_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/main_font"
                        android:text="www.yourapp.com/privacy"
                        android:textColor="@color/white"
                        android:textSize="15sp" />

                </carbon.widget.LinearLayout>

            </carbon.widget.LinearLayout>

        </carbon.widget.LinearLayout>

    </carbon.widget.ScrollView>

</carbon.widget.RelativeLayout>