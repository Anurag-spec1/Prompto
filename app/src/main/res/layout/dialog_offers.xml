<?xml version="1.0" encoding="utf-8"?>
<carbon.widget.LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="24dp"
    android:layout_margin="10dp"
    app:carbon_cornerRadius="12dp"
    android:background="@drawable/card_bg"
    app:carbon_stroke="@color/white"
    app:carbon_strokeWidth="2dp"
    android:gravity="center">

    <ImageView
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:src="@drawable/ic_subscription"
        android:tint="@color/carbon_red_500" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:text="Unlock Prompt Without Interuption"
        android:fontFamily="@font/main_font"
        android:textColor="@color/white"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Enjoy seamless access to prompts!\nSubscribe to use prompts without ads.Or watch an ad to continue using prompts for free"
        android:fontFamily="@font/main_font"
        android:gravity="center"
        android:textColor="@color/carbon_teal_200"
        android:textSize="18sp"/>



    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="horizontal"
        android:gravity="center">

        <carbon.widget.Button
            android:id="@+id/btn_subscribe"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:text="GO PREMIUM"
            app:carbon_cornerRadius="12dp"
            android:background="@drawable/bg_gradient_button"
            android:textColor="@color/white" />

        <carbon.widget.Button
            android:id="@+id/btn_ad"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="Watch Ad"
            app:carbon_cornerRadius="12dp"
            android:background="@drawable/green_gradient"
            android:textColor="@color/white" />

    </LinearLayout>

</carbon.widget.LinearLayout>